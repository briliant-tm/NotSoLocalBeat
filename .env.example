# LocalBeat Environment Configuration
# Salin file ini ke .env dan sesuaikan dengan lingkungan Anda

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your_secret_key_here_change_this_in_production

# Database
DATABASE_URL=sqlite:///localbeat.db

# Music Folder (untuk Local Mode)
# Ubah path ini ke folder musik Anda
MUSIC_FOLDER=E:\Kakak\Music\Music

# Optional: Untuk deployment di Vercel
# DATABASE_URL=postgresql://user:password@host:port/dbname
